{
  "name": "aoaoe",
  "version": "0.63.0",
  "description": "Autonomous supervisor for agent-of-empires sessions using OpenCode or Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aoaoe": "dist/index.js",
    "aoaoe-chat": "dist/chat.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*",
    "!dist/integration-test.*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test --test-reporter spec dist/*.test.js dist/**/*.test.js",
    "integration-test": "npm run build && node dist/integration-test.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "agent-of-empires",
    "opencode",
    "claude-code",
    "ai-agents",
    "tmux",
    "autonomous"
  ],
  "author": "Keith Adler",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Talador12/agent-of-agent-of-empires.git"
  },
  "homepage": "https://github.com/Talador12/agent-of-agent-of-empires",
  "bugs": {
    "url": "https://github.com/Talador12/agent-of-agent-of-empires/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
